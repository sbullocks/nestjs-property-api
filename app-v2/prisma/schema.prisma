// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          Int         @id @default(autoincrement())
  name        String?
  createdAt   DateTime    @default(now())
  properties  Property[]  // same concept - virtual field does not exist in the database table.
}

model Property {
  id        Int       @id @default(autoincrement())
  tenantId  Int       // foreign key column
  tenant    Tenant    @relation(fields: [tenantId], references: [id]) // the relation field. this is a virtual field and does not exist in the database table. it what allows me to tap into property.tenant.name later and prisma hands back the linked Tenant object.
  name      String
  address   String
  city      String
  state     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
